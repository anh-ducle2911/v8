/* ===== CONSTRAINTS ===== */
let CONS=[];
async function loadConstraints(){try{const d=await api('/api/constraints');CONS=d.items;renderConstraints();}catch(_){}}
function renderConstraints(){
  const F=[['khu_vuc','Khu vực'],['loai_xe','Loại xe'],['tai_trong_cam','Tải trọng cấm'],['tuyen','Tuyến'],['gio_bat_dau','Từ'],['gio_ket_thuc','Đến'],['ngay_ap_dung','Ngày áp dụng'],['nguon_quy_dinh','Nguồn quy định'],['ngay_hieu_luc','Ngày hiệu lực'],['ghi_chu','Ghi chú']];
  let h='<thead><tr>'+F.map(f=>`<th>${esc(f[1])}</th>`).join('')+'<th>Áp dụng</th><th></th></tr></thead><tbody>';
  CONS.forEach((c,i)=>{h+='<tr>'+F.map(f=>`<td><span class="edit" contenteditable="true" data-i="${i}" data-f="${f[0]}" onblur="editCons(this)">${esc(c[f[0]]||'')}</span></td>`).join('')+
    `<td style="text-align:center"><input type="checkbox" ${c.hieu_luc!==false?'checked':''} onchange="CONS[${i}].hieu_luc=this.checked"></td>
     <td><button class="btn btn-line btn-sm" onclick="CONS.splice(${i},1);renderConstraints()">Xóa</button></td></tr>`;});
  if(!CONS.length)h+=`<tr><td colspan="${F.length+2}" class="empty">Chưa có quy định.</td></tr>`;
  $('#cons-tbl').innerHTML=h+'</tbody>';
}
function editCons(el){CONS[+el.dataset.i][el.dataset.f]=el.textContent.trim();}
function addConstraint(){CONS.push({id:'RB-'+Date.now(),khu_vuc:'',loai_xe:'',tai_trong_cam:'',tuyen:'',gio_bat_dau:'06:00',gio_ket_thuc:'09:00',ngay_ap_dung:'Tất cả các ngày',nguon_quy_dinh:'',ngay_hieu_luc:'Đang áp dụng',ghi_chu:'',hieu_luc:true});renderConstraints();}
async function saveConstraints(){try{const d=await api('/api/constraints',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({items:CONS})});
  CONS=d.items;renderConstraints();toast('Đã lưu ràng buộc vận hành. Khung giờ cấm tải hiện hành: '+d.window,'ok');}catch(e){toast(e.message,'err');}}

/* ===== MODULE 8: AI dock ===== */
const QUICK=['Gợi ý cho trang này','Tuyến nào km rỗng cao nhất?','Đơn backhaul nào tăng fill-rate tốt nhất?','Giá dầu hiện tại?','Có nên dùng xe standby không?','Vì sao đơn chưa được gán?'];
function toggleDock(open){$('#dock').classList.toggle('show',open);
  if(open&&!$('#dock-msgs').children.length){
    $('#dock-quick').innerHTML=QUICK.map(q=>`<span class="qchip" onclick="quickAsk('${esc(q)}')">${esc(q)}</span>`).join('');
    pushMsg('ai','Xin chào, tôi là Trợ lý AI trực tuyến. Tôi truy cập dữ liệu trong phiên (kế hoạch tuyến, tài chính, sự cố, ghép chiều về…) và Internet — bạn có thể hỏi tất tần tật. Bấm “Gợi ý cho trang này” để xem gợi ý theo module đang mở.','');
  }}
function quickAsk(q){if(q==='Gợi ý cho trang này'){aiSuggestCurrent();return;}$('#dock-q').value=q;askAI();}
async function aiSuggestCurrent(){
  const m=STATE.view||'plan';
  const tmp=document.createElement('div');tmp.className='msg ai';tmp.innerHTML='<span class="spin"></span> Đang tạo gợi ý cho trang…';$('#dock-msgs').appendChild(tmp);$('#dock-msgs').scrollTop=1e9;
  try{const d=await api('/api/ai/suggest?module='+encodeURIComponent(m));
    tmp.remove();pushMsg('ai','Gợi ý cho trang đang mở:\n'+d.text,'Nguồn: '+d.source);$('#dock-src').textContent='Nguồn: '+d.source;
  }catch(e){tmp.remove();pushMsg('ai','Lỗi: '+e.message,'');}
}
function pushMsg(who,text,src){const d=document.createElement('div');d.className='msg '+who;d.innerHTML=esc(text)+(src?`<div class="src">${esc(src)}</div>`:'');$('#dock-msgs').appendChild(d);$('#dock-msgs').scrollTop=1e9;}
async function askAI(){
  const q=$('#dock-q').value.trim();if(!q)return;$('#dock-q').value='';pushMsg('me',q,'');
  const tmp=document.createElement('div');tmp.className='msg ai';tmp.innerHTML='<span class="spin"></span>';$('#dock-msgs').appendChild(tmp);$('#dock-msgs').scrollTop=1e9;
  try{const d=await api('/api/assistant',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({question:q})});
    tmp.remove();pushMsg('ai',d.answer,'Nguồn: '+d.source);$('#dock-src').textContent='Nguồn trả lời: '+d.source;
  }catch(e){tmp.remove();pushMsg('ai','Lỗi: '+e.message,'');}
}

function exportExcel(){if(!STATE.routes){toast('Hãy chạy Kế hoạch tuyến trước khi xuất','err');return;}
  toast('<span class="spin"></span> Đang tạo file Excel…');window.location='/api/export';setTimeout(()=>toast('Đã xuất báo cáo Excel','ok'),900);}

/* drag & drop upload */
['static','dynamic','backhaul'].forEach(k=>{
  const z=document.querySelector(`#f-${k}`).previousElementSibling;
  ['dragover','dragenter'].forEach(e=>z.addEventListener(e,ev=>{ev.preventDefault();z.classList.add('drag')}));
  ['dragleave','drop'].forEach(e=>z.addEventListener(e,ev=>{ev.preventDefault();z.classList.remove('drag')}));
  z.addEventListener('drop',ev=>{const f=ev.dataTransfer.files[0];if(f){const i=document.querySelector(`#f-${k}`);i.files=ev.dataTransfer.files;upload(i,k);}});
});

/* init */
renderFinParams({});refreshStatus().then(()=>{loadLog();loadPreview();});
</script>
