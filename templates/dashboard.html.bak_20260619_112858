/* ===== MAP (OSRM real roads) ===== */
function vIcon(color,size){size=size||9;return L.divIcon({className:'',html:`<div style="width:${size}px;height:${size}px;background:${color};border:1.5px solid #fff;border-radius:50%;box-shadow:0 1px 2px rgba(0,0,0,.3)"></div>`,iconSize:[size,size]});}
function depotIcon(){return L.divIcon({className:'',html:`<div style="width:14px;height:14px;background:#0B3D91;border:2px solid #fff;border-radius:3px;box-shadow:0 1px 3px rgba(0,0,0,.4)"></div>`,iconSize:[14,14],iconAnchor:[7,7]});}
function numIcon(color,num){return L.divIcon({className:'',html:`<div style="width:15px;height:15px;background:${color};border:1.5px solid #fff;border-radius:50%;box-shadow:0 1px 2px rgba(0,0,0,.32);color:#fff;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center">${num}</div>`,iconSize:[15,15],iconAnchor:[7.5,7.5]});}
function bkIcon(){return L.divIcon({className:'',html:`<div style="width:16px;height:16px;background:#1B7A2F;border:2px solid #fff;transform:rotate(45deg);box-shadow:0 1px 3px rgba(0,0,0,.45)"></div>`,iconSize:[16,16],iconAnchor:[8,8]});}
function baseTiles(){return L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',{attribution:'© OpenStreetMap · © CARTO',subdomains:'abcd',maxZoom:19});}
async function osrmGeometry(coords){
  if(coords.length<2)return null;
  const cs=coords.map(c=>c[1]+','+c[0]).join(';');
  try{
    const r=await fetch(`https://router.project-osrm.org/route/v1/driving/${cs}?overview=full&geometries=geojson`);
    const j=await r.json();
    if(j.code!=='Ok'||!j.routes||!j.routes.length)return null;
    return j.routes[0].geometry.coordinates.map(p=>[p[1],p[0]]);
  }catch(_){return null;}
}
function getMap(id){
  let m=STATE.maps[id];
  if(!m){m=L.map(id,{zoomControl:true}).setView([20.6,105.9],7);baseTiles().addTo(m);STATE.maps[id]=m;}
  m.eachLayer(l=>{if(l instanceof L.Marker||l instanceof L.Polyline||l instanceof L.CircleMarker)m.removeLayer(l);});
  return m;
}
async function drawRoutes(mapId,filterId,fitVehicle){
  const m=getMap(mapId);
  let data;try{data=await api('/api/map_data');}catch(_){return;}
  const filter=filterId&&$(filterId)?$(filterId).value:'';
  const bounds=[];let straightUsed=false;
  data.depots.forEach(dp=>{L.marker([dp.lat,dp.lon],{icon:depotIcon()}).addTo(m).bindPopup(`<b>Depot · ${esc(dp.name)}</b><br>${esc(dp.type)} · ${esc(dp.province)}`);bounds.push([dp.lat,dp.lon]);});
  (data.unassigned||[]).forEach(o=>{L.marker([o.lat,o.lon],{icon:vIcon('#9AA7BD',10)}).addTo(m).bindPopup(`Đơn chưa gán: <b>${esc(o.order_id)}</b><br>${esc(o.name||'')}<br>Lý do: ${esc(o.reason)}`);});
  const routes=data.routes.filter(r=>!filter||r.vehicle_id===filter);
  await Promise.all(routes.map(async r=>{
    const pts=r.stops.map(s=>[s.lat,s.lon]);pts.forEach(p=>bounds.push(p));
    let seq=0;
    r.stops.forEach(s=>{
      if(s.type==='depot'){L.marker([s.lat,s.lon],{icon:depotIcon()}).addTo(m).bindPopup(`<b>Depot</b><br>${esc(s.name||'')}${s.eta?('<br>Giờ '+esc(s.eta)):''}`);return;}
      seq++;const col=s.type==='pickup'?'#1565C0':'#E2231A';const lbl=s.type==='pickup'?'Điểm lấy':'Điểm trả';
      L.marker([s.lat,s.lon],{icon:numIcon(col,seq)}).addTo(m).bindPopup(`<b>${seq}. ${lbl}</b><br>${esc(s.name||'')}${s.order_id?('<br>Đơn '+esc(s.order_id)):''}${s.eta?('<br>ETA '+esc(s.eta)):''}<br>Xe ${esc(r.vehicle_id)}`);
    });
    const geo=await osrmGeometry(pts);
    if(geo)L.polyline(geo,{color:r.color,weight:4,opacity:.82}).addTo(m).bindPopup(`Xe ${esc(r.vehicle_id)} · ${esc(r.vehicle_type)}<br>${r.n_orders} đơn · ${r.distance_km} km${r.has_backhaul?' · có backhaul':''}`);
    else{straightUsed=true;L.polyline(pts,{color:r.color,weight:3,opacity:.55,dashArray:'7'}).addTo(m).bindPopup(`Xe ${esc(r.vehicle_id)} · tuyến tham chiếu (chưa lấy được tuyến đường bộ)`);}
  }));
  let fb=bounds;
  if(fitVehicle){const rv=data.routes.find(r=>r.vehicle_id===fitVehicle);if(rv)fb=rv.stops.map(s=>[s.lat,s.lon]);}
  if(fb.length)m.fitBounds(fb,{padding:[30,30]});
  setTimeout(()=>m.invalidateSize(),60);
  if(straightUsed)toast('Không tìm thấy tuyến đường bộ phù hợp cho một số tuyến. Vui lòng kiểm tra lại địa chỉ hoặc tọa độ.','err');
}
