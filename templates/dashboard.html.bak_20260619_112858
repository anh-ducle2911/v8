<script>
const $=s=>document.querySelector(s), $$=s=>document.querySelectorAll(s);
const fmtV=n=>(n==null||isNaN(n))?'—':Math.round(n).toLocaleString('vi-VN')+' đ';
const fmtN=n=>(n==null||isNaN(n))?'—':Number(n).toLocaleString('vi-VN');
const esc=s=>String(s==null?'':s).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
let STATE={view:'import',scenarios:[],scenario:null,routes:null,unassigned:null,preview:[],pvcols:[],validate:[],
  log:[],incident:null,selOption:null,maps:{},backhaul:null,presets:[],weights:{},preset:'can_bang'};

function toast(msg,type){const t=$('#toast');t.className='toast show '+(type||'');t.innerHTML=msg;clearTimeout(t._t);t._t=setTimeout(()=>t.className='toast',3400);}
async function api(url,opt){const r=await fetch(url,opt);if(!r.ok){let e='Có lỗi xảy ra';try{e=(await r.json()).error||e}catch(_){}throw new Error(e);}return r.json();}
function kpi(l,v,sub,cls){return `<div class="kpi ${cls||''}"><div class="lbl">${esc(l)}</div><div class="val">${v}</div><div class="vsub">${esc(sub||'')}</div></div>`;}

/* nav */
$$('.nav-item').forEach(it=>it.onclick=()=>nav(it.dataset.view));
function nav(v){
  STATE.view=v;
  $$('.nav-item').forEach(n=>n.classList.toggle('active',n.dataset.view===v));
  $$('.view').forEach(s=>s.classList.toggle('show',s.id==='view-'+v));
  $('.content').scrollTop=0;
  if(v==='import')loadPreview();
  if(v==='validate')loadValidate();
  if(v==='backhaul')loadBackhaulOrders();
  if(v==='incident')loadIncidents();
  if(v==='log'){loadLog();loadOptLog();}
  if(v==='constraints')loadConstraints();
  if(v==='finance')loadFuel();
  if(v==='map')setTimeout(drawFullMap,80);
  if(v==='plan')setTimeout(()=>STATE.maps.map&&STATE.maps.map.invalidateSize(),80);
}

/* status */
async function refreshStatus(){
  const s=await api('/api/status');
  const chip=$('#chip-ai');chip.classList.toggle('on',s.ai_online);
  chip.innerHTML=`<span class="dot"></span> Trợ lý AI: ${esc(s.ai_provider)}`;
  STATE.scenarios=s.scenarios||[];
  buildScenarioSelects();
  if(s.fuel)STATE.fuel=s.fuel;
  if(s.incident_count){$('#nav-inc').style.display='inline-block';$('#nav-inc').textContent=s.incident_count;}else $('#nav-inc').style.display='none';
  if(s.log_count){$('#nav-log').style.display='inline-block';$('#nav-log').textContent=s.log_count;}
  if(s.static_loaded)$('#info-static').innerHTML=pill('Đã nạp dữ liệu kế hoạch',`${s.fleet} xe · kịch bản ${(s.scenarios||[]).join(', ')}`);
  if(s.dynamic_loaded)$('#info-dynamic').innerHTML=pill('Đã nạp dữ liệu sự cố',`${s.dynamic_cases} sự cố từ file`);
  if(s.backhaul_orders)$('#info-backhaul').innerHTML=pill('Đã nạp đơn quay đầu',`${s.backhaul_orders} đơn ghép chiều về`);
}
function pill(t,sub){return `<div class="file-pill"><div><b>${esc(t)}</b><div style="font-weight:500;color:var(--muted)">${esc(sub)}</div></div></div>`;}
const SCEN_VI={S1:'Kịch bản 1 — Nhu cầu ổn định',S2:'Kịch bản 2 — Nhu cầu tăng cao',S3:'Kịch bản 3 — Phát sinh sự cố'};
function scenarioVN(code){return SCEN_VI[code]||code;}
function buildScenarioSelects(){
  const opts=STATE.scenarios.map(s=>`<option value="${s}">${esc(SCEN_VI[s]||s)}</option>`).join('');
  ['#sel-scenario','#plan-scenario'].forEach(id=>{const el=$(id);if(el)el.innerHTML=opts;});
  if(!STATE.scenario)STATE.scenario=STATE.scenarios[0];
  ['#sel-scenario','#plan-scenario'].forEach(id=>{const el=$(id);if(el)el.value=STATE.scenario||'';});
}
function onPlanScenario(v){STATE.scenario=v;const s=$('#sel-scenario');if(s)s.value=v;}

/* ===== MODULE 1 ===== */
async function upload(input,kind){
  const f=input.files[0];if(!f)return;
  const fd=new FormData();fd.append('file',f);fd.append('kind',kind);
  try{toast('<span class="spin"></span> Đang đọc dữ liệu…');
    const d=await api('/api/import',{method:'POST',body:fd});
    if(d.kind==='static'){$('#info-static').innerHTML=pill(d.filename,d.message);renderMapping(d);STATE.scenario=null;}
    else if(d.kind==='dynamic')$('#info-dynamic').innerHTML=pill(d.filename,d.message);
    else if(d.kind==='backhaul'){$('#info-backhaul').innerHTML=pill(d.filename,d.message);loadBackhaulOrders();}
    await refreshStatus();if(d.kind==='static')loadPreview();
    toast('Đã nạp: '+d.message,'ok');
    if(d.reoptimized)refreshPlanAfterAuto();
  }catch(e){toast(e.message,'err');}
  input.value='';
}
async function loadDemo(){
  try{toast('<span class="spin"></span> Đang nạp dữ liệu mẫu…');
    const d=await api('/api/load_demo',{method:'POST'});
    if(d.static){$('#info-static').innerHTML=pill(d.static.filename,d.static.message);renderMapping(d.static);}
    if(d.dynamic)$('#info-dynamic').innerHTML=pill(d.dynamic.filename,d.dynamic.message);
    STATE.scenario=null;await refreshStatus();loadPreview();toast('Đã nạp dữ liệu mẫu','ok');
  }catch(e){toast(e.message,'err');}
}
function renderMapping(d){
  if(!d.ai_mapping||!Object.keys(d.ai_mapping).length){$('#ai-map-card').style.display='none';return;}
  $('#ai-map-card').style.display='block';
  $('#ai-map-source').innerHTML=`Nguồn ánh xạ: <b>${esc(d.ai_source)}</b> · khớp ${d.ai_matched||0}/${d.ai_total||'?'} trường`;
  let h='<thead><tr><th>Trường chuẩn của hệ thống</th><th>Cột trong file của bạn</th></tr></thead><tbody>';
  for(const k in d.ai_mapping)h+=`<tr><td><span class="tag blue">${esc(k)}</span></td><td>${esc(d.ai_mapping[k])}</td></tr>`;
  $('#ai-map-tbl').innerHTML=h+'</tbody>';
}
async function loadPreview(){
  if(!STATE.scenarios.length){$('#pv-tbl').innerHTML='<tbody><tr><td class="empty">Chưa có dữ liệu. Hãy nạp dữ liệu tĩnh hoặc bấm “Nạp dữ liệu mẫu”.</td></tr></tbody>';return;}
  const sid=STATE.scenario||STATE.scenarios[0];
  try{const d=await api('/api/preview?scenario='+sid);STATE.preview=d.rows;STATE.pvcols=d.columns;renderPreview();}
  catch(e){$('#pv-tbl').innerHTML='<tbody><tr><td class="empty">'+esc(e.message)+'</td></tr></tbody>';}
}
function renderPreview(){
  const q=($('#pv-search').value||'').toLowerCase();
  const cols=STATE.pvcols||[];
  const rows=STATE.preview.filter(r=>!q||String(r.order_id).toLowerCase().includes(q)||String(r.customer||'').toLowerCase().includes(q));
  let h='<thead><tr>'+cols.map(c=>`<th>${esc(c[1])}</th>`).join('')+'<th></th></tr></thead><tbody>';
  rows.forEach(r=>{
    h+='<tr>'+cols.map(c=>{
      const k=c[0];const editable=!['order_id','drop_tw_start','drop_tw_end'].includes(k);
      const val=r[k]==null?'':r[k];
      if(!editable)return `<td>${esc(val)}</td>`;
      return `<td><span class="edit" contenteditable="true" data-id="${esc(r.order_id)}" data-field="${k}" onblur="saveCell(this)">${esc(val)}</span></td>`;
    }).join('')+`<td><button class="btn btn-line btn-sm" onclick="delOrder('${esc(r.order_id)}')">Xóa</button></td></tr>`;
  });
  if(!rows.length)h+='<tr><td colspan="'+(cols.length+1)+'" class="empty">Không có đơn phù hợp.</td></tr>';
  $('#pv-tbl').innerHTML=h+'</tbody>';
}
async function saveCell(el){
  const id=el.dataset.id,field=el.dataset.field,value=el.textContent.trim();
  try{await api('/api/order/update',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({scenario:STATE.scenario,order_id:id,field,value})});
    const row=STATE.preview.find(r=>String(r.order_id)===String(id));if(row)row[field]=value;
    toast('Đã lưu thay đổi đơn '+id,'ok');
  }catch(e){toast(e.message,'err');}
}
function toggleAddForm(){const f=$('#add-form');f.style.display=f.style.display==='none'?'block':'none';}
async function addOrder(){
  const body={scenario:STATE.scenario,order_id:$('#ad-id').value,customer:$('#ad-cust').value,corridor:$('#ad-cor').value,
    min_vehicle:$('#ad-veh').value,pickup_name:$('#ad-pn').value,pickup_lat:$('#ad-plat').value,pickup_lon:$('#ad-plon').value,
    delivery_name:$('#ad-dn').value,delivery_lat:$('#ad-dlat').value,delivery_lon:$('#ad-dlon').value,
    weight_kg:$('#ad-w').value,volume_m3:$('#ad-vol').value,drop_tw_start:$('#ad-tws').value,drop_tw_end:$('#ad-twe').value,
    revenue:$('#ad-rev').value,priority:'B'};
  try{const d=await api('/api/order/add',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
    toast('Đã thêm đơn '+d.order_id,'ok');toggleAddForm();loadPreview();
    if(d.reoptimized)refreshPlanAfterAuto();
  }catch(e){toast(e.message,'err');}
}
async function delOrder(id){
  if(!confirm('Xóa đơn '+id+' khỏi danh sách làm việc?'))return;
  try{const d=await api('/api/order/delete',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({scenario:STATE.scenario,order_id:id})});
    loadPreview();toast('Đã xóa đơn '+id,'ok');if(d.reoptimized)refreshPlanAfterAuto();}catch(e){toast(e.message,'err');}
}

/* ===== MODULE 2 ===== */
async function loadValidate(){
  if(!STATE.scenarios.length){$('#cap-banner').innerHTML='<div class="empty">Chưa có dữ liệu tĩnh. Hãy nạp dữ liệu ở Module 1.</div>';$('#val-tbl').innerHTML='';return;}
  STATE.scenario=$('#sel-scenario').value||STATE.scenario||STATE.scenarios[0];
  $('#val-sid').textContent=STATE.scenario;
  $('#cap-banner').innerHTML='<div class="loading"><span class="spin"></span>Đang kiểm định…</div>';
  try{
    const d=await api('/api/validate?scenario='+STATE.scenario);STATE.validate=d.orders;
    const c=d.scenario;const cls=c.scenario.startsWith('S1')?'bn-s1':c.scenario.startsWith('S2')?'bn-s2':'bn-s3';
    const scnTitle=c.scenario.replace('S1 —','Kịch bản 1 —').replace('S2 —','Kịch bản 2 —').replace('S3 —','Kịch bản 3 —');
    $('#cap-banner').innerHTML=`<div class="banner ${cls}"><div><div class="big">${esc(scnTitle)}</div>
      <div>${esc(c.mode)} · ${c.n_orders} đơn / ${c.n_vehicles} xe khả dụng · Chênh lệch năng lực: ${c.gap>=0?'+':''}${c.gap}</div>
      <div style="font-weight:500;margin-top:3px">${esc(c.strategy)}</div></div></div>`;
    $('#val-kpis').innerHTML=
      kpi('Tổng đơn',c.n_orders,'','navy')+
      kpi('Không thể xử lý',d.summary.error_orders,'thiếu dữ liệu cứng','red')+
      kpi('Cần rà soát',d.summary.review_orders,'cấm tải · tách đơn · chiều về','amber')+
      kpi('Xe khả dụng',c.n_vehicles,'cần khoảng '+c.need,'green');
    $('#ai-narr').style.display='block';
    $('#ai-narr').innerHTML=`<div class="ai-h">Nhận định dữ liệu (Trợ lý AI · ${esc(d.ai_source)})</div><div>${esc(d.ai_narrative)}</div>`;
    renderValidate();
  }catch(e){$('#cap-banner').innerHTML='<div class="empty">'+esc(e.message)+'</div>';}
}
function renderValidate(){
  const q=($('#val-search').value||'').toLowerCase(),f=$('#val-filter').value;
  const rows=STATE.validate.filter(o=>(!q||String(o.order_id).toLowerCase().includes(q))&&(!f||o.status===f));
  let h='<thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Tuyến</th><th class="num">KL(kg)</th><th>Loại xe</th><th>Khung giao</th><th class="num">Doanh thu</th><th>Trạng thái</th><th>Lý do cần xem xét</th><th>Ghi chú điều phối</th><th></th></tr></thead><tbody>';
  rows.forEach(o=>{
    const rc=o.status==='Không thể xử lý'?'row-err':o.status==='Cần rà soát'?'row-rev':'';
    const bd=o.status==='Không thể xử lý'?'b-err':o.status==='Cần rà soát'?'b-rev':'b-ok';
    const issues=o.issues.length?o.issues.map(i=>`<span class="tag red">${esc(i)}</span>`).join(''):'<span class="tag" style="background:var(--green-l);color:var(--green)">Hợp lệ</span>';
    const act=o.status!=='Hợp lệ'?`<button class="btn btn-red btn-sm" onclick="quickIncident('${esc(o.order_id)}','${esc(o.incident_hint)}')">Xử lý sự cố</button>`:'';
    h+=`<tr class="${rc}"><td><b>${esc(o.order_id)}</b>${o.inner_city?' <span class="tag">nội đô</span>':''}</td>
      <td>${esc(o.customer)}</td><td>${esc(o.corridor)}</td><td class="num">${fmtN(o.weight_kg)}</td>
      <td>${esc(o.min_vehicle)}</td><td>${esc(o.drop_tw)}</td><td class="num">${fmtN(o.revenue)}</td>
      <td><span class="badge ${bd}">${esc(o.status)}</span></td><td>${issues}</td>
      <td><span class="edit" contenteditable="true" data-id="${esc(o.order_id)}" onblur="saveNote(this)">${esc(o.note||'')}</span></td>
      <td>${act}</td></tr>`;
  });
  if(!rows.length)h+='<tr><td colspan="11" class="empty">Không có đơn phù hợp.</td></tr>';
  $('#val-tbl').innerHTML=h+'</tbody>';
}
async function saveNote(el){
  const id=el.dataset.id,value=el.textContent.trim();
  try{await api('/api/order/update',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({scenario:STATE.scenario,order_id:id,field:'note',value})});
    const r=STATE.validate.find(o=>String(o.order_id)===String(id));if(r)r.note=value;toast('Đã lưu ghi chú đơn '+id,'ok');
  }catch(e){toast(e.message,'err');}
}
function quickIncident(id,hint){nav('incident');setTimeout(()=>{$('#inc-order').value=id;if(hint)selectIncType(hint);createIncident();},150);}

/* ===== MODULE 3 ===== */
async function runOptimize(){
  if(!STATE.scenarios.length){toast('Hãy nạp dữ liệu tĩnh trước','err');return;}
  STATE.scenario=STATE.scenario||STATE.scenarios[0];
  $('#plan-kpis').innerHTML='<div class="loading"><span class="spin"></span>Đang chạy Hybrid Engine (Greedy → OR-Tools)…</div>';
  $('#plan-kpis2').innerHTML='';
  try{
    const d=await api('/api/optimize',{method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({scenario:STATE.scenario,preset:'can_bang'})});
    applyPlan(d);
    toast('Đã lập kế hoạch '+d.n_vehicles_used+' tuyến · '+(d.engine||''),'ok');
  }catch(e){$('#plan-kpis').innerHTML='<div class="empty">'+esc(e.message)+'</div>';}
}
function applyPlan(d){
  STATE.routes=d.routes;STATE.unassigned=d.unassigned;STATE.plan=d;
  $('#plan-engine').textContent=(d.engine||'')+' · Bấm “Timeline” để xem ETA; khóa tuyến đã chốt để giữ khi tối ưu lại.';
  const sbCls=d.standby_ok?'green':'amber';
  // Hàng KPI 1 — kết quả gán
  $('#plan-kpis').innerHTML=
    kpi('Xe sử dụng',d.n_vehicles_used,'','navy')+
    kpi('Đơn được gán',d.n_orders_assigned+'/'+d.n_orders_total,'','green')+
    kpi('Đơn chưa gán',d.n_unassigned,d.n_unassigned?'cần xử lý':'tất cả đã gán',d.n_unassigned?'red':'green')+
    kpi('Xe standby',d.n_standby,'mục tiêu 3–5 xe',sbCls);
  // Hàng KPI 2 — quãng đường & tài chính
  $('#plan-kpis2').innerHTML=
    kpi('Tổng km',fmtN(d.total_km)+' km','có tải + rỗng','navy')+
    kpi('Km rỗng',fmtN(d.empty_km)+' km',(d.empty_km_pct||0)+'% tổng quãng',d.empty_km_pct>20?'amber':'green')+
    kpi('Doanh thu / Chi phí',fmtN(d.revenue_total)+' / '+fmtN(d.total_cost),'đồng','blue')+
    kpi('Lợi nhuận',fmtV(d.profit),'biên '+(d.margin||0)+'%',d.profit>=0?'green':'red');
  renderEngineInfo(d);
  renderPlanTable();renderUnassigned();fillMapFilter();drawPlanMap();
}
function renderEngineInfo(d){
  const el=$('#engine-info');if(!el)return;el.style.display='block';
  const fb=d.fallback?`<span class="tag red">fallback: ${esc(d.fallback)}</span>`:'<span class="tag" style="background:var(--green-l);color:var(--green)">không fallback</span>';
  const modeTag=`<span class="tag blue">chế độ: ${esc(d.engine_mode||'hybrid')}</span>`;
  const auto=d.auto_optimize;
  el.innerHTML=`<div style="display:flex;flex-wrap:wrap;gap:14px;align-items:center;justify-content:space-between">
    <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:center">
      <b style="color:var(--navy)">Engine:</b> ${esc(d.engine||'—')} ${modeTag}
      <span class="tag">thời gian chạy: ${d.elapsed_sec!=null?d.elapsed_sec+'s':'—'}</span>
      <span class="tag">giới hạn: ${d.time_limit_sec||'—'}s</span>
      ${d.improved?'<span class="tag" style="background:var(--green-l);color:var(--green)">OR-Tools đã cải thiện</span>':''} ${fb}
    </div>
    <div style="display:flex;gap:8px;align-items:center">
      <label class="lab" style="margin:0">Tự tối ưu khi có đơn mới</label>
      <button class="btn btn-sm ${auto?'btn-navy':'btn-line'}" onclick="toggleAuto(${auto?'false':'true'})">${auto?'ĐANG BẬT':'ĐANG TẮT'}</button>
      <button class="btn btn-line btn-sm" onclick="nav('log');loadOptLog()">Nhật ký tối ưu</button>
    </div>
  </div>`;
}
async function toggleAuto(on){
  try{const d=await api('/api/config',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({auto_optimize:on})});
    if(STATE.plan){STATE.plan.auto_optimize=d.auto_optimize;renderEngineInfo(STATE.plan);}
    toast('Tự tối ưu khi có đơn mới: '+(d.auto_optimize?'BẬT':'TẮT'),'ok');
  }catch(e){toast(e.message,'err');}
}
async function refreshPlanAfterAuto(){
  try{const d=await api('/api/plan');if(d&&d.has_plan){applyPlan(d);toast('Đã tự tối ưu lại theo dữ liệu mới (giữ nguyên tuyến đã khóa).','ok');}}catch(_){}
}
function _firstEta(r,t){const s=(r.stops||[]).find(x=>x.type===t);return s&&s.eta?s.eta:'—';}
function _lastEta(r,t){const a=(r.stops||[]).filter(x=>x.type===t);return a.length&&a[a.length-1].eta?a[a.length-1].eta:'—';}
function renderPlanTable(){
  let h='<thead><tr><th>Mã xe</th><th>Loại</th><th>Tài xế</th><th>Tuyến</th><th class="num">Đơn</th><th class="num">Km</th><th class="num">Km rỗng</th><th class="num">Tải%</th><th>Lấy đầu</th><th>Trả cuối</th><th class="num">Lợi nhuận</th><th class="num">Biên%</th><th>Backhaul</th><th>Trạng thái tuyến</th><th></th></tr></thead><tbody>';
  const ST=[['assigned','Đã gán'],['locked','Đã khóa'],['in_progress','Đang chạy'],['completed','Hoàn thành']];
  STATE.routes.forEach(r=>{
    const bh=r.has_backhaul?'<span class="tag" style="background:var(--green-l);color:var(--green)">có</span>':'<span class="tag">—</span>';
    const sel=`<select class="field" style="padding:4px 6px;font-size:11px" onclick="event.stopPropagation()" onchange="setRouteStatus('${esc(r.vehicle_id)}',this.value)">`+
      ST.map(s=>`<option value="${s[0]}"${(r.status||'assigned')===s[0]?' selected':''}>${s[1]}</option>`).join('')+'</select>';
    const rowCls=r.locked?'clickable" style="background:#f1f7ff':'clickable';
    h+=`<tr class="${rowCls}" onclick="focusRoute('${esc(r.vehicle_id)}')"><td><b>${esc(r.vehicle_id)}</b>${r.locked?' 🔒':''}</td>
      <td>${esc(r.vehicle_type)}</td><td>${esc(r.driver)}</td><td>${esc(r.corridor)}</td>
      <td class="num">${r.n_orders}</td><td class="num">${r.distance_km}</td><td class="num">${fmtN(r.empty_km)}</td><td class="num">${r.fill_weight_pct}%</td>
      <td>${esc(_firstEta(r,'pickup'))}</td><td>${esc(_lastEta(r,'delivery'))}</td>
      <td class="num" style="color:${r.profit<0?'var(--red)':'var(--green)'}">${fmtN(r.profit)}</td><td class="num">${r.margin}%</td>
      <td>${bh}</td><td>${sel}</td>
      <td><button class="btn btn-soft btn-sm" onclick="event.stopPropagation();openRouteTimeline('${esc(r.vehicle_id)}')">Timeline</button></td></tr>`;
  });
  if(!STATE.routes.length)h+='<tr><td colspan="15" class="empty">Chưa có tuyến. Bấm “Chạy kế hoạch tuyến”.</td></tr>';
  $('#plan-tbl').innerHTML=h+'</tbody>';
}
async function setRouteStatus(vid,status){
  try{const d=await api('/api/route/status',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({vehicle_id:vid,status})});
    const r=(STATE.routes||[]).find(x=>x.vehicle_id===vid);if(r){r.status=d.status;r.locked=d.locked;}
    renderPlanTable();
    const lbl={assigned:'Đã gán (cho phép tối ưu lại)',locked:'Đã khóa',in_progress:'Đang chạy',completed:'Hoàn thành'}[d.status];
    toast('Tuyến '+vid+': '+lbl+(d.locked?' — sẽ KHÔNG bị đổi khi tối ưu lại':''),'ok');
  }catch(e){toast(e.message,'err');}
}
function openRouteTimeline(vid){
  const r=(STATE.routes||[]).find(x=>x.vehicle_id===vid);if(!r)return;
  const cmap={depot:'#0B3D91',pickup:'#1565C0',delivery:'#E2231A',backhaul:'#1B7A2F',check:'#5B6678'};
