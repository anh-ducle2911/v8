<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hòa Phát Logistics — Trung tâm điều phối & tối ưu tuyến</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<style>
:root{
  --navy:#0B3D91; --navy-d:#072a66; --blue:#1565C0; --blue-l:#EAF1FB;
  --red:#E2231A; --red-d:#B71C1C; --red-l:#FCEDEC;
  --bg:#F4F7FB; --card:#FFFFFF; --ink:#16203A; --muted:#5B6678; --line:#E2E8F2;
  --green:#1B7A2F; --green-l:#E8F5EC; --amber:#B07A00; --amber-l:#FFF6E2;
  --shadow:0 1px 4px rgba(16,40,90,.06); --shadow-l:0 12px 40px rgba(11,61,145,.20);
  --radius:12px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{font-family:'Be Vietnam Pro',system-ui,Segoe UI,Roboto,sans-serif;background:var(--bg);color:var(--ink);font-size:14px;line-height:1.5;-webkit-font-smoothing:antialiased}
a{color:var(--blue);text-decoration:none}
::-webkit-scrollbar{width:9px;height:9px}
::-webkit-scrollbar-thumb{background:#c8d3e4;border-radius:8px;border:2px solid var(--bg)}
::-webkit-scrollbar-thumb:hover{background:#aebdd6}

.topbar{height:58px;background:#fff;border-bottom:1px solid var(--line);display:flex;align-items:center;gap:14px;padding:0 20px;position:sticky;top:0;z-index:60}
.brand{display:flex;align-items:center;gap:11px}
.logo{width:38px;height:38px;border-radius:8px;background:var(--navy);display:grid;place-items:center;font-weight:800;color:#fff;font-size:13px;letter-spacing:-.5px;box-shadow:inset 0 0 0 2px var(--red)}
.brand h1{font-size:15px;font-weight:700;color:var(--navy);line-height:1.15}
.brand .sub{font-size:11px;color:var(--muted);font-weight:500}
.topbar .spacer{flex:1}
.chip{display:inline-flex;align-items:center;gap:7px;background:var(--blue-l);border:1px solid #d3e1f6;padding:6px 12px;border-radius:8px;font-size:12px;font-weight:600;color:var(--navy)}
.chip .dot{width:8px;height:8px;border-radius:50%;background:#9fb0cc}
.chip.on .dot{background:#2faa4d}
.btn{font-family:inherit;font-weight:600;border:1px solid transparent;border-radius:9px;padding:9px 15px;cursor:pointer;font-size:13px;display:inline-flex;align-items:center;gap:7px;transition:.13s;white-space:nowrap}
.btn:active{transform:translateY(1px)}
.btn-red{background:var(--red);color:#fff}.btn-red:hover{background:var(--red-d)}
.btn-navy{background:var(--navy);color:#fff}.btn-navy:hover{background:var(--navy-d)}
.btn-blue{background:var(--blue);color:#fff}.btn-blue:hover{background:var(--navy)}
.btn-soft{background:var(--blue-l);color:var(--navy);border-color:#d3e1f6}.btn-soft:hover{background:#dde9fb}
.btn-line{background:#fff;color:var(--navy);border-color:var(--line)}.btn-line:hover{background:#f5f8fd}
.btn-sm{padding:6px 11px;font-size:12px;border-radius:7px}
.btn[disabled]{opacity:.5;cursor:not-allowed}

.app{display:flex;height:calc(100vh - 58px)}
.sidebar{width:250px;background:var(--card);border-right:1px solid var(--line);padding:12px 10px;overflow-y:auto;flex-shrink:0}
.nav-group{font-size:10.5px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;margin:14px 10px 6px}
.nav-item{display:flex;align-items:center;gap:11px;padding:9px 11px;border-radius:9px;cursor:pointer;font-weight:600;color:#3a465e;margin-bottom:2px;transition:.12s;position:relative;font-size:13px}
.nav-item:hover{background:var(--blue-l)}
.nav-item.active{background:var(--navy);color:#fff}
.nav-item .num{width:22px;height:22px;border-radius:6px;background:var(--blue-l);color:var(--navy);display:grid;place-items:center;font-size:12px;font-weight:700;flex-shrink:0}
.nav-item.active .num{background:rgba(255,255,255,.22);color:#fff}
.nav-item.alert .num{background:var(--red-l);color:var(--red)}
.nav-item.active.alert{background:var(--red)}
.nav-badge{position:absolute;right:9px;background:var(--red);color:#fff;border-radius:9px;font-size:10.5px;padding:1px 7px;font-weight:700}
.nav-item.active .nav-badge{background:#fff;color:var(--red)}

.content{flex:1;overflow-y:auto;padding:20px 24px 80px}
.view{display:none}
.view.show{display:block}
.page-head{display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:16px;flex-wrap:wrap}
.page-head h2{font-size:20px;font-weight:800;color:var(--navy);letter-spacing:-.2px}
.page-head .desc{color:var(--muted);font-size:13px;margin-top:3px;max-width:720px}
.step-tag{font-size:11px;font-weight:700;color:var(--blue);background:var(--blue-l);padding:3px 10px;border-radius:6px;display:inline-block;margin-bottom:7px}

.card{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);padding:16px 18px;margin-bottom:15px}
.card h3{font-size:14.5px;font-weight:700;color:var(--navy);margin-bottom:3px}
.card .hint{color:var(--muted);font-size:12.5px;margin-bottom:12px}
.grid{display:grid;gap:14px}
.grid>*{min-width:0}
.g2{grid-template-columns:1fr 1fr}.g3{grid-template-columns:repeat(3,1fr)}.g4{grid-template-columns:repeat(4,1fr)}
@media(max-width:1150px){.g3,.g4{grid-template-columns:repeat(2,1fr)}.g2{grid-template-columns:1fr}}

.kpi{background:var(--card);border:1px solid var(--line);border-radius:var(--radius);padding:14px 16px;box-shadow:var(--shadow);position:relative;overflow:hidden}
.kpi::before{content:"";position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--blue)}
.kpi.red::before{background:var(--red)}.kpi.green::before{background:var(--green)}.kpi.amber::before{background:var(--amber)}.kpi.navy::before{background:var(--navy)}
.kpi .lbl{font-size:11.5px;color:var(--muted);font-weight:600}
.kpi .val{font-size:23px;font-weight:800;color:var(--navy);margin-top:3px;line-height:1.1}
.kpi.red .val{color:var(--red-d)}.kpi.green .val{color:var(--green)}
.kpi .vsub{font-size:11.5px;color:var(--muted);margin-top:2px;font-weight:500}

.tbl-wrap{overflow:auto;border:1px solid var(--line);border-radius:10px;max-height:480px}
table{width:100%;border-collapse:collapse;font-size:12.7px}
thead th{background:#f1f5fb;color:var(--navy);font-weight:700;text-align:left;padding:10px 11px;border-bottom:2px solid #e1e9f4;white-space:nowrap;position:sticky;top:0;z-index:1}
tbody td{padding:8px 11px;border-bottom:1px solid #eef2f8;white-space:nowrap}
tbody tr:hover{background:#f6faff}
tbody tr.clickable{cursor:pointer}
tbody tr.row-err{background:var(--red-l)}
tbody tr.row-rev{background:#fff8e8}
tfoot td{padding:10px 11px;font-weight:800;background:#fbeceb;border-top:2px solid #f3c9c6;color:var(--navy)}
.num{text-align:right;font-variant-numeric:tabular-nums}
td .edit{border:1px solid transparent;border-radius:6px;padding:3px 6px;min-width:60px;cursor:text;display:inline-block}
td .edit:hover{border-color:#cdd9ec;background:#fff}
td .edit:focus{outline:0;border-color:var(--blue);background:#fff;box-shadow:0 0 0 2px var(--blue-l)}

.badge{display:inline-flex;align-items:center;padding:3px 9px;border-radius:6px;font-size:11px;font-weight:700}
.b-ok{background:var(--green-l);color:var(--green)}
.b-rev{background:var(--amber-l);color:var(--amber)}
.b-err{background:var(--red-l);color:var(--red)}
.b-blue{background:var(--blue-l);color:var(--navy)}
.b-gray{background:#eef1f6;color:#5b6678}
.tag{display:inline-block;padding:2px 8px;border-radius:5px;background:#eef1f6;font-size:11px;font-weight:600;color:#475168;margin:1px 2px}
.tag.red{background:var(--red-l);color:var(--red-d)}
.tag.blue{background:var(--blue-l);color:var(--navy)}

.toolbar{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:11px}
.field{border:1px solid var(--line);border-radius:8px;padding:8px 11px;font-family:inherit;font-size:13px;background:#fff}
.field:focus{outline:0;border-color:var(--blue);box-shadow:0 0 0 3px var(--blue-l)}
select.field{cursor:pointer}
label.lab{font-size:12px;font-weight:600;color:#3a465e;display:block;margin-bottom:4px}

#map,#bk-map,#inc-map{height:430px;width:100%;background:#dfe7f1;border-radius:10px}
.map-legend{display:flex;gap:14px;flex-wrap:wrap;padding:10px 4px 0;font-size:12px;color:var(--muted);font-weight:600}
.leg{display:inline-flex;align-items:center;gap:6px}.leg .sw{width:12px;height:12px;border-radius:50%}

.drop{border:2px dashed #c6d4ea;border-radius:11px;padding:20px;text-align:center;background:#fafcff;transition:.13s;cursor:pointer}
.drop:hover,.drop.drag{border-color:var(--blue);background:var(--blue-l)}
.file-pill{display:flex;align-items:center;gap:8px;background:var(--blue-l);border-radius:8px;padding:8px 12px;margin-top:10px;font-size:12.5px;font-weight:600;color:var(--navy)}

.ai-box{background:#f7faff;border:1px solid #dce6f5;border-left:3px solid var(--blue);border-radius:10px;padding:13px 15px}
.ai-box .ai-h{font-weight:700;color:var(--navy);font-size:13px;margin-bottom:5px}

.banner{border-radius:10px;padding:13px 16px;font-weight:600;display:flex;align-items:center;gap:14px}
.banner .big{font-size:16px;font-weight:800}
.bn-s1{background:var(--green-l);color:var(--green);border:1px solid #bfe6c8}
.bn-s2{background:var(--blue-l);color:var(--navy);border:1px solid #c6dbf6}
.bn-s3{background:var(--red-l);color:var(--red-d);border:1px solid #f3c9c6}

.preset-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
.preset{padding:9px 14px;border-radius:9px;background:#fff;border:1px solid var(--line);cursor:pointer;font-weight:600;font-size:12.5px;color:#3a465e}
.preset:hover{border-color:var(--blue)}
.preset.active{background:var(--navy);color:#fff;border-color:var(--navy)}
.slider-row{margin-bottom:13px}
.slider-row .top{display:flex;justify-content:space-between;font-size:12.5px;font-weight:600;color:#3a465e}
.slider-row .ex{font-size:11.5px;color:var(--muted);margin-top:2px}
input[type=range]{width:100%;margin-top:6px;accent-color:var(--navy)}

.indicator{position:relative;height:30px;border-radius:8px;display:flex;overflow:hidden;border:1px solid var(--line)}
.indicator .seg{flex:1;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff}
.indicator .needle{position:absolute;top:-4px;bottom:-4px;width:3px;background:#111;border-radius:2px;box-shadow:0 0 0 2px #fff}
.ind-scale{display:flex;justify-content:space-between;font-size:10.5px;color:var(--muted);margin-top:4px;font-weight:600}

.formula{background:#f7f9fc;border:1px solid var(--line);border-radius:10px;padding:15px 17px;font-size:13px;line-height:1.9}
.formula .row{display:flex;justify-content:space-between;gap:14px;padding:3px 0;border-bottom:1px dashed #e6ecf5}
.formula .row:last-child{border-bottom:0}
.formula .lbl{color:#3a465e}.formula .lbl b{color:var(--navy)}
.formula .res{font-weight:800;color:var(--green)}

.opt{border:1px solid var(--line);border-radius:10px;padding:13px 15px;margin-bottom:10px;cursor:pointer;transition:.12s}
.opt:hover{border-color:var(--blue)}
.opt.sel{border-color:var(--green);background:var(--green-l);box-shadow:0 0 0 1px var(--green)}
.opt .ot{font-weight:700;font-size:13.5px;color:var(--navy);display:flex;justify-content:space-between;gap:10px;align-items:center}
.opt .od{font-size:12.5px;color:var(--muted);margin:5px 0}
.opt .metrics{display:flex;gap:8px;flex-wrap:wrap;font-size:11.5px}
.metric{background:#f1f5fb;border-radius:6px;padding:3px 8px;font-weight:600;color:#3a465e}
.play{border-left:3px solid var(--blue);background:#f7faff;border-radius:0 8px 8px 0;padding:10px 13px;margin-bottom:9px}
.play .sit{font-weight:700;font-size:12.5px;color:var(--navy)}
.play .act{font-size:12px;margin-top:2px}
.play .script{font-size:12px;color:#3a465e;font-style:italic;background:#fff;border:1px dashed #cdd9ec;border-radius:7px;padding:7px 10px;margin-top:6px}

.ov{position:fixed;inset:0;background:rgba(10,22,48,.45);z-index:200;display:none}
.ov.show{display:block}
.modal{position:fixed;top:40px;left:50%;transform:translateX(-50%);width:min(1000px,95vw);max-height:90vh;background:var(--card);border-radius:14px;box-shadow:var(--shadow-l);z-index:201;display:none;flex-direction:column;overflow:hidden;border:1px solid #d6e0f0}
.modal.show{display:flex}
.modal-head{background:var(--navy);color:#fff;padding:14px 18px;display:flex;align-items:center;gap:12px}
.modal-head .mt{font-weight:800;font-size:15px;flex:1}
.modal-x{background:rgba(255,255,255,.18);border:0;color:#fff;width:30px;height:30px;border-radius:7px;cursor:pointer;font-size:15px;font-weight:700}
.modal-body{padding:18px;overflow-y:auto}
.modal-foot{padding:12px 18px;border-top:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;gap:10px;background:#fafcff;flex-wrap:wrap}
.split{display:grid;grid-template-columns:1.15fr .85fr;gap:16px}
@media(max-width:920px){.split{grid-template-columns:1fr}}
.kv{display:flex;justify-content:space-between;gap:10px;padding:6px 0;border-bottom:1px dashed #eef2f8;font-size:12.8px}
.kv .k{color:var(--muted);font-weight:600}.kv .v{font-weight:700;color:var(--ink);text-align:right}
.empty{text-align:center;color:var(--muted);padding:30px 16px;font-size:13px}

.toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:var(--navy);color:#fff;padding:12px 18px;border-radius:10px;box-shadow:var(--shadow-l);z-index:400;font-weight:600;font-size:13px;display:none;max-width:460px}
.toast.show{display:block}
.toast.ok{background:var(--green)}.toast.err{background:var(--red)}
.spin{width:15px;height:15px;border:2.5px solid rgba(0,0,0,.15);border-top-color:var(--navy);border-radius:50%;animation:sp .7s linear infinite;display:inline-block;vertical-align:-2px}
@keyframes sp{to{transform:rotate(360deg)}}
.loading{display:grid;place-items:center;padding:36px;color:var(--muted);gap:10px}

/* Trợ lý AI: cửa sổ NỔI nhỏ góc dưới phải, overlay z-index cao, KHÔNG đẩy layout */
.dock{position:fixed;right:22px;bottom:22px;z-index:1200}
.dock-btn{background:var(--navy);color:#fff;border:0;border-radius:30px;padding:15px 26px;font-weight:800;font-size:15px;cursor:pointer;box-shadow:var(--shadow-l);font-family:inherit;display:inline-flex;align-items:center;gap:9px;transition:.13s}
.dock-btn:hover{background:var(--navy-d);transform:translateY(-1px)}
.dock-btn .pulse{width:9px;height:9px;border-radius:50%;background:#37d67a;animation:pls 1.8s infinite}
@keyframes pls{0%{box-shadow:0 0 0 0 rgba(55,214,122,.55)}70%{box-shadow:0 0 0 9px rgba(55,214,122,0)}100%{box-shadow:0 0 0 0 rgba(55,214,122,0)}}
.dock-panel{position:fixed;right:22px;bottom:88px;width:394px;max-width:94vw;height:min(70vh,580px);background:#fff;border:1px solid var(--line);border-radius:16px;box-shadow:var(--shadow-l);z-index:1201;display:none;flex-direction:column;overflow:hidden}
.dock-panel.show{display:flex}
@media(max-width:560px){.dock-panel{right:3vw;left:3vw;width:auto}}
.dock-head{background:var(--navy);color:#fff;padding:12px 15px;display:flex;align-items:center;justify-content:space-between}
.dock-head .t{font-weight:700;font-size:13.5px}
.dock-head .s{font-size:11px;opacity:.85}
.dock-msgs{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:10px;background:#f7faff}
.msg{max-width:88%;padding:9px 12px;border-radius:11px;font-size:12.8px;line-height:1.5;white-space:pre-wrap}
.msg.me{align-self:flex-end;background:var(--navy);color:#fff;border-bottom-right-radius:3px}
.msg.ai{align-self:flex-start;background:#fff;border:1px solid var(--line);border-bottom-left-radius:3px}
.msg .src{font-size:10px;color:var(--muted);margin-top:4px}
.dock-quick{display:flex;gap:6px;flex-wrap:wrap;padding:8px 12px;border-top:1px solid var(--line);background:#fff}
.qchip{font-size:11px;background:var(--blue-l);color:var(--navy);border:1px solid #d3e1f6;border-radius:14px;padding:4px 9px;cursor:pointer;font-weight:600}
.dock-input{display:flex;gap:7px;padding:10px 12px;border-top:1px solid var(--line);background:#fff}
.dock-input input{flex:1;border:1px solid var(--line);border-radius:9px;padding:9px 11px;font-family:inherit;font-size:13px}
.dock-input input:focus{outline:0;border-color:var(--blue);box-shadow:0 0 0 3px var(--blue-l)}
.hl{background:linear-gradient(transparent 60%,#ffe680 60%);padding:0 2px;font-weight:700}
.mini{font-size:12.3px}
</style>
</head>
<body>

<div class="topbar">
  <div class="brand">
    <div class="logo">HPL</div>
    <div>
      <h1>Hòa Phát Logistics — Trung tâm điều phối</h1>
      <div class="sub">Hệ thống điều phối &amp; tối ưu tuyến vận tải</div>
    </div>
  </div>
  <div class="spacer"></div>
  <span class="chip" id="chip-ai"><span class="dot"></span> Trợ lý AI: đang kiểm tra…</span>
  <button class="btn btn-line btn-sm" onclick="loadDemo()">Nạp dữ liệu mẫu</button>
  <button class="btn btn-red btn-sm" onclick="exportExcel()">Xuất Excel</button>
</div>

<div class="app">
  <nav class="sidebar">
    <div class="nav-group">Lập kế hoạch</div>
    <div class="nav-item active" data-view="import"><span class="num">1</span> Nhập dữ liệu &amp; ánh xạ</div>
    <div class="nav-item" data-view="validate"><span class="num">2</span> Kiểm định dữ liệu</div>
    <div class="nav-item" data-view="plan"><span class="num">3</span> Kế hoạch tuyến &amp; bản đồ</div>
    <div class="nav-item" data-view="backhaul"><span class="num">4</span> Ghép chuyến quay đầu</div>
    <div class="nav-item" data-view="finance"><span class="num">5</span> Tài chính P&amp;L</div>
    <div class="nav-group">Điều phối trong ngày</div>
    <div class="nav-item" data-view="incident"><span class="num">6</span> Phát hiện &amp; xử lý sự cố <span class="nav-badge" id="nav-inc" style="display:none">0</span></div>
    <div class="nav-item" data-view="log"><span class="num">7</span> Nhật ký &amp; lưu vết <span class="nav-badge" id="nav-log" style="display:none">0</span></div>
    <div class="nav-group">Cấu hình &amp; trực quan</div>
    <div class="nav-item" data-view="constraints"><span class="num">R</span> Ràng buộc vận hành</div>
    <div class="nav-item" data-view="map"><span class="num">B</span> Bản đồ điều phối</div>
  </nav>

  <main class="content">

  <!-- ===== MODULE 1: IMPORT ===== -->
  <section class="view show" id="view-import">
    <div class="page-head"><div>
      <h2>Nhập dữ liệu &amp; ánh xạ</h2>
      <div class="desc">Tải Excel (tĩnh · động · đơn bổ sung), ánh xạ cột tự động, xem trước &amp; sửa trực tiếp.</div>
    </div></div>

    <div class="grid g3">
      <div class="card">
        <h3>Dữ liệu lập kế hoạch</h3>
        <div class="hint">Đơn hàng · đội xe · tài xế · depot · chi phí · ràng buộc.</div>
        <div class="drop" onclick="document.getElementById('f-static').click()">
          <div style="font-weight:700">Kéo thả hoặc bấm để chọn file .xlsx</div>
          <div style="color:var(--muted);font-size:12px;margin-top:3px">Định dạng .xlsx hoặc .xlsm</div>
        </div>
        <input type="file" id="f-static" accept=".xlsx,.xlsm" hidden onchange="upload(this,'static')">
        <div id="info-static"></div>
      </div>
      <div class="card">
